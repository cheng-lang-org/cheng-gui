fn detectTemplateRuntimeFallback(runtimeSource: str): bool =
    if len(runtimeSource) == 0:
        return false
    if cpContainsToken(runtimeSource, "legacy.mountUnimakerAot"):
        return true
    if cpContainsToken(runtimeSource, "legacy.unimakerDispatch"):
        return true
    if cpContainsToken(runtimeSource, "legacy.unimakerDrainEffects"):
        return true
    if cpContainsToken(runtimeSource, "legacy.unimakerResolveTargetAt"):
        return true
    if cpContainsToken(runtimeSource, "APP_HOME"):
        return true
    if cpContainsToken(runtimeSource, "Welcome to "):
        return true
    if cpContainsToken(runtimeSource, "mountUnimakerAot"):
        return true
    if cpContainsToken(runtimeSource, "unimakerDispatch"):
        return true
    return false

