@importc("fopen")
fn bridge_fopen(path: char*, mode: char*): void*
@importc("fclose")
fn bridge_fclose(stream: void*): int32
@importc("fread")
fn bridge_fread(ptr: void*, size: int64, n: int64, stream: void*): int64
@importc("fwrite")
fn bridge_fwrite(ptr: void*, size: int64, n: int64, stream: void*): int64
@importc("mkdir")
fn bridge_mkdir(path: char*, mode: int32): int32

@ exportc("cheng_fopen")
fn chengFopenBridge(path: char*, mode: char*): void* =
    return bridge_fopen(path, mode)

@ exportc("cheng_fclose")
fn chengFcloseBridge(stream: void*): int32 =
    return bridge_fclose(stream)

@ exportc("cheng_fread")
fn chengFreadBridge(ptr: void*, size: int64, n: int64, stream: void*): int32 =
    let got: int64 = bridge_fread(ptr, size, n, stream)
    if got <= 0:
        return int32(0)
    if got > int64(2147483647):
        return int32(2147483647)
    return int32(got)

@ exportc("cheng_fwrite")
fn chengFwriteBridge(ptr: void*, size: int64, n: int64, stream: void*): int32 =
    let wrote: int64 = bridge_fwrite(ptr, size, n, stream)
    if wrote <= 0:
        return int32(0)
    if wrote > int64(2147483647):
        return int32(2147483647)
    return int32(wrote)

@ exportc("cheng_iometer_call")
fn chengIometerCallBridge(hook: void*, op: int32, bytes: int64) =
    return

@ exportc("cheng_mkdir1")
fn chengMkdir1Bridge(path: char*): int32 =
    if path == nil:
        return int32(-1)
    return bridge_mkdir(path, int32(493))

