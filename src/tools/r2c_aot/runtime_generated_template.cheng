        panel = panel + "<div id='chart' style='height:180px;background:#dbeafe;border-radius:12px;margin-top:8px;'></div>"
        panel = panel + "<button id='trading-crosshair' style='margin-top:8px;padding:10px;border:none;border-radius:10px;background:#111827;color:#ffffff;'>Crosshair</button>"
        return panel
