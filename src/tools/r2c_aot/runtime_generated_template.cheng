        panel = panel + "<div id='home-search-open' style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Search Panel Open</div>"
        return panel
    if strEq(route, "home_sort_open"):
        panel = panel + "<div id='home-sort-open' style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Sort Panel Open</div>"
        return panel
    if strEq(route, "home_channel_manager_open"):
        panel = panel + "<div id='home-channel-manager-open' style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Channel Manager Open</div>"
        return panel
    if strEq(route, "home_content_detail_open"):
        panel = panel + "<div id='home-content-detail-open' style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Content Detail Open</div>"
        return panel
    if strEq(route, "home_ecom_overlay_open"):
        panel = panel + "<div id='home-ecom-overlay-open' style='background:#111827;color:#f8fafc;border-radius:14px;padding:12px;margin-top:10px;'>Ecom Overlay Open</div>"
        return panel
    if strEq(route, "home_bazi_overlay_open"):
        panel = panel + "<div id='home-bazi-overlay-open' style='background:#111827;color:#f8fafc;border-radius:14px;padding:12px;margin-top:10px;'>Bazi Overlay Open</div>"
        return panel
    if strEq(route, "home_ziwei_overlay_open"):
        panel = panel + "<div id='home-ziwei-overlay-open' style='background:#111827;color:#f8fafc;border-radius:14px;padding:12px;margin-top:10px;'>Ziwei Overlay Open</div>"
        return panel
    if strEq(route, "tab_messages"):
        panel = panel + "<div style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Message Timeline</div>"
        return panel
    if strEq(route, "tab_nodes"):
        panel = panel + "<div style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Node Dashboard</div>"
        return panel
    if strEq(route, "tab_profile") || strEq(route, "update_center_main"):
        panel = panel + "<div style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:12px;margin-top:10px;'>Profile Dashboard</div>"
        return panel
    if strEq(route, "publish_selector"):
        panel = panel + "<div id='publish-selector' style='display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;'>"
        panel = panel + "<button id='publish-content' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Content</button>"
        panel = panel + "<button id='publish-product' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Product</button>"
        panel = panel + "<button id='publish-live' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Live</button>"
        panel = panel + "<button id='publish-app' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>App</button>"
        panel = panel + "<button id='publish-food' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Food</button>"
        panel = panel + "<button id='publish-ride' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Ride</button>"
        panel = panel + "<button id='publish-job' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Job</button>"
        panel = panel + "<button id='publish-hire' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Hire</button>"
        panel = panel + "<button id='publish-rent' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Rent</button>"
        panel = panel + "<button id='publish-sell' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Sell</button>"
        panel = panel + "<button id='publish-secondhand' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Secondhand</button>"
        panel = panel + "<button id='publish-crowdfunding' style='padding:10px;border:none;border-radius:10px;background:#ffffff;'>Crowdfunding</button>"
        panel = panel + "</div>"
