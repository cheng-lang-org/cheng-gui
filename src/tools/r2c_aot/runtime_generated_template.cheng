import gui/browser/web
import gui/browser/r2capp/ime_bridge
import gui/browser/r2capp/utfzh_bridge
import gui/browser/r2capp/utfzh_editor

type
    ComponentUnit = ref
        componentId: str
        routeState: str
        mounted: bool
        mountCount: int32
        updateCount: int32
        unmountCount: int32

var mountedPage: web.BrowserPage = nil
var componentUnits: ComponentUnit[]

fn strEq(a, b: str): bool =
    if len(a) < len(b):
        return false
    if len(a) > len(b):
        return false
    var idx: int32 = int32(0)
    while idx < len(a):
        if int32(a[idx]) != int32(b[idx]):
            return false
        idx = idx + int32(1)
    return true

fn appendComponentUnit(componentId, routeState: str) =
    var unit: ComponentUnit
    new(unit)
    unit.componentId = componentId
    unit.routeState = routeState
    unit.mounted = false
    unit.mountCount = int32(0)
    unit.updateCount = int32(0)
    unit.unmountCount = int32(0)
    let idx = len(componentUnits)
    setLen(componentUnits, idx + int32(1))
    componentUnits[idx] = unit

fn ensureComponentUnits() =
    if len(componentUnits) > int32(0):
        return
    appendComponentUnit("cu_0", "__R2C_DEFAULT_ROUTE__")

fn componentUnitForRoute(routeState: str): ComponentUnit =
    var idx: int32 = int32(0)
    while idx < len(componentUnits):
        let unit = componentUnits[idx]
        if unit != nil && strEq(unit.routeState, routeState):
            return unit
        idx = idx + int32(1)
    return nil

fn isKnownRoute(route: str): bool =
__R2C_KNOWN_ROUTE_CASES__
    return false

fn normalizeSelector(targetSelector: str): str =
    if len(targetSelector) <= int32(0):
        return ""
    if strEq(targetSelector, "#"):
        return ""
    if targetSelector[0] == '#':
        return targetSelector[1..<len(targetSelector)]
    return targetSelector

fn routeFromSelectorId(id: str): str =
    if len(id) == int32(0):
        return ""
    if strEq(id, "publish-cancel") || strEq(id, "publish-close") || strEq(id, "publish-dismiss") || strEq(id, "cancel-publish"):
        return "__R2C_DEFAULT_ROUTE__"
    if strEq(id, "publish-selector-cancel") || strEq(id, "publish-selector-close"):
        return "__R2C_DEFAULT_ROUTE__"
    if strEq(id, "tab-home"):
        return "home_default"
    if strEq(id, "tab-messages"):
        return "tab_messages"
    if strEq(id, "tab-publish"):
        return "publish_selector"
    if strEq(id, "tab-nodes"):
        return "tab_nodes"
    if strEq(id, "tab-profile"):
        return "tab_profile"
    if strEq(id, "sidebar-open") || strEq(id, "home-sidebar-open") || strEq(id, "menu-open"):
        return "sidebar_open"
__R2C_SELECTOR_ROUTE_CASES__
    return ""

fn routePrimaryTab(route: str): str =
    if len(route) <= int32(0):
        return "home"
    if strEq(route, "home_default") || strEq(route, "sidebar_open") || strEq(route, "lang_select"):
        return "home"
    if strEq(route, "tab_messages"):
        return "messages"
    if strEq(route, "tab_nodes"):
        return "nodes"
    if strEq(route, "tab_profile") || strEq(route, "update_center_main"):
        return "profile"
    if strEq(route, "publish_selector") || strEq(route, "publish_content") || strEq(route, "publish_product") ||
       strEq(route, "publish_live") || strEq(route, "publish_app") || strEq(route, "publish_food") ||
       strEq(route, "publish_ride") || strEq(route, "publish_job") || strEq(route, "publish_hire") ||
       strEq(route, "publish_rent") || strEq(route, "publish_sell") ||
       strEq(route, "publish_secondhand") || strEq(route, "publish_crowdfunding"):
        return "publish"
    if strEq(route, "home_search_open") || strEq(route, "home_sort_open") ||
       strEq(route, "home_channel_manager_open") || strEq(route, "home_content_detail_open") ||
       strEq(route, "home_ecom_overlay_open") || strEq(route, "home_bazi_overlay_open") ||
       strEq(route, "home_ziwei_overlay_open") || strEq(route, "trading_main") ||
       strEq(route, "trading_crosshair") || strEq(route, "ecom_main") || strEq(route, "marketplace_main"):
        return "home"
    return "home"

