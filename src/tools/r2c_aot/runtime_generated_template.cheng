        return "Home"
    if strEq(route, "home_default"):
        return "Home"
    if strEq(route, "sidebar_open"):
        return "Sidebar"
    if strEq(route, "tab_messages"):
        return "Messages"
    if strEq(route, "publish_selector"):
        return "Publish"
    if strEq(route, "tab_nodes"):
        return "Nodes"
    if strEq(route, "tab_profile"):
        return "Profile"
    if strEq(route, "home_search_open"):
        return "Search"
    if strEq(route, "home_sort_open"):
        return "Sort"
    if strEq(route, "home_channel_manager_open"):
        return "Channel Manager"
    if strEq(route, "home_content_detail_open"):
        return "Content Detail"
    if strEq(route, "home_ecom_overlay_open"):
        return "Ecom Overlay"
    if strEq(route, "home_bazi_overlay_open"):
        return "Bazi Overlay"
    if strEq(route, "home_ziwei_overlay_open"):
        return "Ziwei Overlay"
    if strEq(route, "publish_content"):
        return "Publish Content"
    if strEq(route, "publish_product"):
        return "Publish Product"
    if strEq(route, "publish_live"):
        return "Publish Live"
    if strEq(route, "publish_app"):
        return "Publish App"
    if strEq(route, "publish_food"):
        return "Publish Food"
    if strEq(route, "publish_ride"):
        return "Publish Ride"
    if strEq(route, "publish_job"):
        return "Publish Job"
    if strEq(route, "publish_hire"):
        return "Publish Hire"
    if strEq(route, "publish_rent"):
        return "Publish Rent"
    if strEq(route, "publish_sell"):
        return "Publish Sell"
    if strEq(route, "publish_secondhand"):
        return "Publish Secondhand"
    if strEq(route, "publish_crowdfunding"):
        return "Publish Crowdfunding"
    if strEq(route, "trading_main"):
        return "Trading"
    if strEq(route, "trading_crosshair"):
        return "Trading Crosshair"
    if strEq(route, "ecom_main"):
        return "Ecom"
    if strEq(route, "marketplace_main"):
        return "Marketplace"
    if strEq(route, "update_center_main"):
        return "Update Center"
    return route

fn navButtonStyle(active: bool): str =
    if active:
        return "padding:10px 8px;border:none;border-radius:10px;background:#111827;color:#ffffff;font-size:14px;"
    return "padding:10px 8px;border:none;border-radius:10px;background:#e5e7eb;color:#111827;font-size:14px;"

fn routeSpecificPanel(route: str): str =
    var panel = ""
    if strEq(route, "sidebar_open"):
        panel = panel + "<div id='sidebar-open' style='background:#ffffff;border:1px solid #d1d5db;border-radius:14px;padding:14px;margin-top:10px;'>"
        panel = panel + "<div style='font-weight:700;margin-bottom:8px;'>Sidebar</div>"
        panel = panel + "<div id='trading-main' style='padding:8px;border-radius:8px;background:#f1f5f9;margin:6px 0;'>Trading Entrance</div>"
        panel = panel + "<div id='marketplace-main' style='padding:8px;border-radius:8px;background:#f1f5f9;margin:6px 0;'>Marketplace Entrance</div>"
        panel = panel + "<div id='update-center-main' style='padding:8px;border-radius:8px;background:#f1f5f9;margin:6px 0;'>Update Center Entrance</div>"
        panel = panel + "</div>"
        return panel
